# ─────────────────────────────────────────────
# Kavach Backend Environment Variables (Example)
# ─────────────────────────────────────────────

# ═══ Server Config ═════════════════════════════
PORT=8080
NODE_ENV=production

# ═══ LLM API Keys ══════════════════════════════
# Primary OpenAI key (used for User Advocate)
OPENAI_API_KEY="your-openai-api-key"

# Featherless API keys (used for fast, ungated agentic models)
FEATHERLESS_API_KEY_1="your-featherless-api-key-1"
FEATHERLESS_API_KEY_2="your-featherless-api-key-2"

# ═══ Search API Keys ═══════════════════════════
TAVILY_API_KEY="your-tavily-api-key"

# ═══ Security & Enkrypt API ════════════════════
ENKRYPT_API_KEY="your-enkrypt-api-key"

# ═══ Upstash Redis ═════════════════════════════
UPSTASH_REDIS_REST_URL="your-upstash-redis-url"
UPSTASH_REDIS_REST_TOKEN="your-upstash-redis-token"

# ═══ Qdrant Vector DB ══════════════════════════
QDRANT_URL="your-qdrant-cluster-url"
QDRANT_API_KEY="your-qdrant-api-key"

# ═══ Supabase ══════════════════════════════════
SUPABASE_URL="your-supabase-url"
SUPABASE_SERVICE_ROLE_KEY="your-supabase-service-role-key"
